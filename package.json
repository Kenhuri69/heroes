{
  "name": "heroes-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "test": "pnpm --filter @heroes/engine --filter @heroes/content --filter @heroes/client test",
    "build": "pnpm --filter @heroes/client build",
    "dev": "pnpm --filter @heroes/client dev",
    "smoke": "playwright test",
    "content:check": "pnpm --filter @heroes/tools content:check",
    "faction:new": "pnpm --filter @heroes/tools faction:new",
    "faction:validate": "pnpm --filter @heroes/tools faction:validate",
    "faction:sim": "pnpm --filter @heroes/tools faction:sim",
    "map:gen": "pnpm --filter @heroes/tools map:gen"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@playwright/test": "^1.53.0",
    "eslint": "^9.30.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0"
  }
}
